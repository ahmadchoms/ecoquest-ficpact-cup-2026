// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
  SUSPENDED
}

enum MissionType {
  CALCULATOR
  QUIZ
  DRAG_DROP
  SIMULATION
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum MissionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum MissionCategory {
  CLIMATE
  WASTE
  BIODIVERSITY
  COASTAL
  WATER
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum BadgeCategory {
  CLIMATE
  WASTE
  BIODIVERSITY
  COASTAL
  WATER
  EXPLORATION
  MILESTONE
}

enum ThreatLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  password     String
  username     String     @unique
  xp           Int        @default(0)
  level        Int        @default(1)
  profileImage String?
  bio          String?
  role         Role       @default(USER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  badges             Badge[]             @relation("UserBadges")
  missionCompletions MissionCompletion[]
}

model Province {
  id           String       @id @default(cuid())
  name         String       @unique
  region       String
  coordinates  String
  ecosystems   String[]
  threatLevel  ThreatLevel?
  description  String?
  funFact      String?
  species      String[]
  illustration String?
  color        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  missions Mission[]
}

model Mission {
  id           String          @id @default(cuid())
  title        String
  subtitle     String?
  description  String
  type         MissionType
  difficulty   Difficulty
  status       MissionStatus   @default(DRAFT)
  xpReward     Int
  timeEstimate String?
  category     MissionCategory
  component    String?
  icon         String?
  color        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  provinceId String
  province   Province @relation(fields: [provinceId], references: [id], onDelete: Cascade)

  badgeRewardId String?
  badgeReward   Badge?  @relation(fields: [badgeRewardId], references: [id], onDelete: SetNull)

  completions MissionCompletion[]
}

model Badge {
  id          String         @id @default(cuid())
  name        String         @unique
  description String
  icon        String?
  rarity      Rarity
  category    BadgeCategory?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  users    User[]    @relation("UserBadges")
  missions Mission[]
}

model MissionCompletion {
  id          String   @id @default(cuid())
  xpEarned    Int
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  missionId String
  mission   Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId])
}

