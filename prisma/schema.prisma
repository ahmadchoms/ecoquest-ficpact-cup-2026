// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
  SUSPENDED
}

enum MissionType {
  CALCULATOR
  DRAG_DROP
  QUIZ
  SIMULATION
  GAME
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum MissionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum MissionCategory {
  OCEAN
  TRANSPORT
  WATER
  COASTAL
  BIODIVERSITY
  WASTE
  CLIMATE
}

enum Rarity {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
  CHALLENGER
}

enum Region {
  SUMATERA
  JAWA
  KALIMANTAN
  SULAWESI
  PAPUA
  BALI_NUSA_TENGGARA
  MALUKU
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  password     String
  name         String
  username     String     @unique
  xp           Int        @default(0)
  points       Int        @default(0)
  level        Int        @default(1)
  emailVerified DateTime?
  profileImage String?   
  bio          String?
  role         Role       @default(USER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  accounts           Account[]
  sessions           Session[]
  badges             Badge[]             @relation("UserBadges")
  missionCompletions MissionCompletion[]
  accounts           Account[]
  sessions           Session[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Province {
  id          String      @id @default(cuid())
  name        String      @unique
  region      Region
  ecosystems  String[]
  threatLevel Difficulty?
  description String?
  funFact     String?
  species     String[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  missions Mission[]
}

model Mission {
  id           String          @id @default(cuid())
  title        String
  subtitle     String?
  description  String
  type         MissionType
  difficulty   Difficulty
  status       MissionStatus   @default(ACTIVE)
  pointsReward Int
  xpReward     Int
  timeEstimate String?
  category     MissionCategory
  icon         String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  provinceId String
  province   Province @relation(fields: [provinceId], references: [id], onDelete: Cascade)

  badgeRewardId String?
  badgeReward   Badge?  @relation(fields: [badgeRewardId], references: [id], onDelete: SetNull)

  completions MissionCompletion[]
}

model Badge {
  id          String           @id @default(cuid())
  name        String           @unique
  description String
  icon        String?
  rarity      Rarity
  category    MissionCategory?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  users    User[]    @relation("UserBadges")
  missions Mission[]
}

model MissionCompletion {
  id          String   @id @default(cuid())
  xpEarned    Int
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  missionId String
  mission   Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
