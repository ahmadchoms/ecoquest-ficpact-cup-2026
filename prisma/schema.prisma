generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  password           String
  username           String              @unique
  xp                 Int                 @default(0)
  level              Int                 @default(1)
  profileImage       String?
  bio                String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  name               String
  points             Int                 @default(0)
  role               Role                @default(USER)
  status             UserStatus          @default(ACTIVE)
  accounts           Account[]
  missionCompletions MissionCompletion[]
  sessions           Session[]
  userItems          UserItem[]
  badges             Badge[]             @relation("UserBadges")
}

model Province {
  id          String      @id @default(cuid())
  name        String      @unique
  ecosystems  String[]
  description String?
  funFact     String?
  species     String[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  region      Region
  threatLevel Difficulty?
  missions    Mission[]
}

model Mission {
  id            String              @id @default(cuid())
  title         String
  subtitle      String?
  description   String
  xpReward      Int
  timeEstimate  String?
  icon          String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  provinceId    String
  badgeRewardId String?
  pointsReward  Int
  status        MissionStatus       @default(ACTIVE)
  type          MissionType
  difficulty    Difficulty
  category      MissionCategory
  badgeReward   Badge?              @relation(fields: [badgeRewardId], references: [id])
  province      Province            @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  completions   MissionCompletion[]
}

model Badge {
  id          String           @id @default(cuid())
  name        String           @unique
  description String
  icon        String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  rarity      Rarity
  category    MissionCategory?
  missions    Mission[]
  users       User[]           @relation("UserBadges")
}

model MissionCompletion {
  id           String   @id @default(cuid())
  xpEarned     Int
  completedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  userId       String
  missionId    String
  pointsEarned Int      @default(0)
  mission      Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId])
}

model Event {
  id          String     @id @default(cuid())
  name        String
  description String?
  bannerUrl   String?
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  items       ShopItem[]
}

model ShopItem {
  id          String       @id @default(cuid())
  name        String
  description String?
  price       Int
  type        ShopItemType
  content     String
  previewUrl  String?
  isActive    Boolean      @default(true)
  eventId     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  rarity      String       @default("common")
  event       Event?       @relation(fields: [eventId], references: [id])
  purchases   UserItem[]
}

model UserItem {
  id         String   @id @default(cuid())
  userId     String
  itemId     String
  acquiredAt DateTime @default(now())
  item       ShopItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
  SUSPENDED
}

enum MissionType {
  CALCULATOR
  DRAG_DROP
  QUIZ
  SIMULATION
  GAME
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum MissionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum MissionCategory {
  OCEAN
  TRANSPORT
  WATER
  COASTAL
  BIODIVERSITY
  WASTE
  CLIMATE
}

enum Rarity {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
  CHALLENGER
}

enum Region {
  SUMATERA
  JAWA
  KALIMANTAN
  SULAWESI
  PAPUA
  BALI_NUSA_TENGGARA
  MALUKU
}

enum ShopItemType {
  BANNER
  BORDER
}
